# AI Readiness Backend Environment Variables
# Copy this file to .env and fill in the values

# Server
PORT=3002
NODE_ENV=development
CORS_ORIGIN=http://localhost:5174

# OpenAI (Required - STT, LLM, Embeddings)
OPENAI_API_KEY=sk-your-openai-api-key

# Anthropic (Fallback LLM)
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key

# ElevenLabs (TTS)
ELEVENLABS_API_KEY=sk_your-elevenlabs-api-key
ELEVENLABS_VOICE_ID=IKne3meq5aSn9XLyUdCD

# Pinecone (Vector Database for RAG)
ENABLE_PINECONE=true
PINECONE_API_KEY=your-pinecone-api-key
PINECONE_HOST=your-index-host.pinecone.io
PINECONE_INDEX=simo-ai-twin

# Resend (Email Service)
RESEND_API_KEY=re_your-resend-api-key
RESEND_FROM_EMAIL=Simo from AllysAI <simo@allysai.com>

# Database
DATABASE_PATH=./data/simo.db
